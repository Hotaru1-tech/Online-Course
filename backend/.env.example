PORT=4000

# Local MySQL (running outside Docker)
# DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/online_course"

# Docker Compose MySQL
DATABASE_URL="mysql://app:app@localhost:3307/online_course"

JWT_SECRET="change-this-for-production"
